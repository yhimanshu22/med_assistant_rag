# Copy to .env and adjust for your environment:
#   cp .env.example .env

# JWT signing key — generate a long random value for production:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-in-production-use-a-long-random-secret

# SQLite (default) or PostgreSQL, e.g. postgresql://user:pass@localhost:5432/medassist
DATABASE_URL=sqlite:///./users.db

# Ragas faithfulness/relevance scoring (adds extra LLM calls; slow on CPU)
ENABLE_RAG_EVALUATION=false

# Comma-separated frontend origins allowed by CORS
CORS_ORIGINS=http://localhost:5173

# Observability (JSON logs to stdout; optional Sentry — pip install sentry-sdk)
LOG_LEVEL=INFO
APP_ENV=development
SENTRY_DSN=

# Defer TinyLlama load until first chat query (API starts faster; set true if startup crashes)
LAZY_LLM_LOAD=false
